---
import { Image } from 'astro:assets'
import { Zoom } from 'starlight-image-zoom/components'

import mainVisual from './img/pen2.webp'
---

<section class="not-prose relative left-1/2 right-1/2 -ml-[50vw] -mr-[50vw] w-screen overflow-hidden bg-slate-900 py-20 lg:py-32" style="margin-bottom:0 !important">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center flex flex-col items-center">
    {/* 1. メインキャッチコピー */}
    <h2 class="text-4xl md:text-6xl mb-6 leading-[1.1] tracking-tight">日報の管理・集計をもっと簡単に</h2>

    {/* 2. サブリード文 */}

    <p class="text-lg md:text-xl mb-10 leading-relaxed max-w-xl">
      「うちの業務に合うアプリがない」と諦めていませんか？
      NipoPlusは、現場のフォーマットをそのままデジタル化できる日報システムです。日報の作成はもちろん、読む・承認する・探す・集計する・CSV/PDF出力するといった、日報業務で必要なことをすべてカバーします。
      今すぐ無料で始めることができます。
    </p>

    {/* 3. アクションボタン（CTA） */}
    <div class="flex flex-col sm:flex-row gap-4 mb-16 w-full sm:w-auto justify-center">
      <a
        href="https://nipoplus.sndbox.jp/"
        class="flex items-center justify-center px-8 py-4 bg-indigo-600 text-white rounded-xl font-bold text-lg hover:bg-indigo-700 transition-all shadow-xl shadow-indigo-900/40"
      >
        今すぐ無料で試してみる
      </a>
      <a
        href="/nipoplus/admin/quickstart/"
        class="flex items-center justify-center px-8 py-4 bg-slate-800 text-slate-300 rounded-xl font-bold text-lg border border-slate-700 hover:bg-slate-700 transition-all"
      >
        操作ガイド
      </a>
    </div>

    {/* 4. ビジュアル（特大サイズのタブレット画面） */}
    <div class="w-full mb-16">
      <div class="rounded-2xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800/50 p-3 shadow-2xl overflow-hidden">
        <Zoom label="タブレットでNipoPlusを使用している様子。テンプレートは自由にカスタマイズ可能。スタイラスペンを使えば日報に直筆サインも記入できます">
          {/* w-full で横幅いっぱいに広げ、操作画面のディテールをくっきり見せます */}
          <Image
            src={mainVisual}
            alt="タブレットでNipoPlusを使用している様子。テンプレートは自由にカスタマイズ可能。スタイラスペンを使えば日報に直筆サインも記入できます"
            class="rounded-xl w-full h-auto transform group-hover:scale-[1.01] transition-transform duration-500"
          />
        </Zoom>
      </div>
    </div>

    {/* 5. ★日報LPへのリンク（最下部にスマートに配置） */}
    <div class="p-4 rounded-xl bg-slate-100 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 w-full max-w-md text-left sm:text-center">
      <p class="text-sm mb-1 font-bold font-sans">点検アプリでお探しですか？</p>
      <a
        href="/lp/checksheet/"
        class="group inline-flex items-center text-blue-600 dark:text-indigo-400 font-bold hover:text-blue-500 dark:hover:text-indigo-300 transition-colors gap-1 text-sm font-sans"
      >
        点検業務に特化した解説ページはこちら
        <span class="transition-transform group-hover:translate-x-1">→</span>
      </a>
    </div>

    <a href="/legacy/about/diff/" class="text-sm">旧Nipoをご利用中の方はこちら</a>
  </div>
</section>
