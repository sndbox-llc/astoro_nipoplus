
<section class="not-prose relative left-1/2 right-1/2 -ml-[50vw] -mr-[50vw] w-screen py-20 px-4 sm:px-6 lg:px-8 bg-slate-50 dark:bg-slate-900/50 my-12 border-y border-slate-100 dark:border-slate-800">
