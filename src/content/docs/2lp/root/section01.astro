---
import { Image } from 'astro:assets'
import { Badge } from '@astrojs/starlight/components'
import { Zoom } from 'starlight-image-zoom/components'

import IMG_Touch from './img/touch.png'
import IMG_Pen2 from './img/pen2.webp'
---

<section class="not-prose relative left-1/2 right-1/2 -ml-[50vw] -mr-[50vw] w-screen py-24">
  <div class="max-w-7xl mx-auto px-5">
    {/* バッジ */}
    <Badge text="時間・場所からの解放" variant="tip" />

    {/* 見出しとリード文 */}
    <h2 class="text-4xl md:text-5xl dark:text-white mb-6 leading-tight tracking-tight">業務終了後に、日報のためだけに事務所へ戻る必要はありません。時間・場所にとらわれない日報ライフを始めよう</h2>
    <p class="text-lg mb-12 leading-relaxed">
      「現場仕事は終わったのに、日報を書くために30分かけて事務所に戻る……」<br />
      そんな非効率な働き方は、もう終わりにしましょう。NipoPlusは、現場の「今」をその場で報告できるクラウドシステムです。
    </p>

    {/* メリット1 説明 */}
    <div class="grid md:grid-cols-2 gap-6 items-center mb-16">
      <div>
        <div class="text-blue-600 dark:text-blue-400 font-black text-5xl mb-4 opacity-20 italic font-serif">01</div>
        <h3 class="text-xl md:text-2xl font-bold mb-6">📱 スマホ・タブレットで隙間時間に報告完了。現場から「直帰」を当たり前に。</h3>
        <p class="leading-relaxed mb-6">
          専用のアプリ（<a href="https://apps.apple.com/jp/app/%E6%97%A5%E5%A0%B1%E3%82%A2%E3%83%97%E3%83%AA-nipoplus/id1625797169">iOS</a> /
          <a href="https://play.google.com/store/apps/details?id=jp.sndbox.nipoplus">Android</a>）や<a href="https://nipoplus.sndbox.jp/">ブラウザ</a>から、いつでもどこでも日報を作成できます。<br />
          キーボード入力が苦手な方でも大丈夫。タップ中心の選択肢形式や、音声入力を活用すれば、わずか数分で報告が完了。現場からそのまま直帰できる環境を整えます。
        </p>

        {/* リンク導線 */}
        <div class="mt-16 flex justify-center lg:justify-end">
          <a href="/nipoplus/system/mobile-install/" class="group flex items-center gap-2 font-bold text-orange-600 dark:text-orange-300">
            モバイルアプリの導入ガイドを読む
            <span class="transition-transform group-hover:translate-x-1">→</span>
          </a>
        </div>
      </div>
      {/* メリット1 画像 */}
      <div>
        <div class="relative bg-white dark:bg-slate-900 rounded-2xl overflow-hidden shadow-2xl border border-slate-200 dark:border-slate-700">
          <Zoom label="様々な補助機能を組み込んだ日報作成画面">
            <Image src={IMG_Touch} alt="様々な補助機能を組み込んだ日報作成画面" width={1000} widths={[500, 1000]} sizes="(max-width: 500px) 500px, 1000px" class="w-full h-auto" />
          </Zoom>

          {/* オーバーレイ */}
          <div class="absolute bottom-4 left-4 right-4 bg-slate-900/80 text-white p-4 rounded-xl text-xs">
            <span>💡 スマホやタブレットからも操作しやすいパーツで日報作成がスムーズ </span>
          </div>
        </div>
      </div>
    </div>

    {/* メリット2 */}
    <div class="grid md:grid-cols-2 gap-6 items-center bg-16">
      <div class="md:order-last">
        <div class="text-blue-600 dark:text-blue-400 font-black text-5xl mb-4 opacity-20 italic font-serif">02</div>
        <h3 class="text-xl md:text-2xl font-bold mb-6">📸 現場写真をその場で一発添付。手書きサインもデジタルで完結。</h3>
        <p class="leading-relaxed mb-6">
          「百聞は一見にしかず」。現場の状況を文章で説明するのは時間がかかります。 カメラで撮った写真をその場で添付すれば、異常箇所の報告やエビデンスも、写真1枚で説得力が格段にアップします。<br />
          指やスタイラスペンで画面に直接サインも可能。紙の報告書のような「署名」の手間もデジタル化できます。
        </p>

        {/* リンク導線 */}
        <div class="mt-16 flex justify-center lg:justify-end">
          <a href="/nipoplus/template/binarys/" class="group flex items-center gap-2 font-bold text-orange-600 dark:text-orange-300">
            写真・サイン機能の詳細を見る
            <span class="transition-transform group-hover:translate-x-1">→</span>
          </a>
        </div>
      </div>
      <div class="relative group">
        <div class="relative bg-white dark:bg-slate-900 rounded-2xl overflow-hidden shadow-2xl border border-slate-200 dark:border-slate-700">
          <Zoom label="タッチパネルによる写真添付やサイン操作">
            <Image src={IMG_Pen2} alt="タッチパネルによる写真添付やサイン操作" width={1000} widths={[500, 1000]} sizes="(max-width: 500px) 500px, 1000px" class="w-full h-auto" />
          </Zoom>
          {/* オーバーレイ */}
          <div class="absolute bottom-4 left-4 right-4 bg-slate-900/80 text-white p-4 rounded-xl text-xs">
            <span>💡 スタイラスペンを使って直筆サインを日報に書き込んだ例 </span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
