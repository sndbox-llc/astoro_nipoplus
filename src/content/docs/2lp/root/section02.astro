---
import { Image } from 'astro:assets'
import { Badge } from '@astrojs/starlight/components'
import { Zoom } from 'starlight-image-zoom/components'

import IMG_Reportbox from './img/reportbox.png'
import IMG_CSV from './img/make-charts_tablet.webp'
---

{
  /*

このセクションコンポーネントをベースとして、コピーで使い回す

▼背景が白のセクション
<section class="not-prose relative left-1/2 right-1/2 -ml-[50vw] -mr-[50vw] w-screen py-24 bg-white dark:bg-slate-900">


▼背景がグレーのレクション
<section class="not-prose relative left-1/2 right-1/2 -ml-[50vw] -mr-[50vw] w-screen py-24 bg-slate-50 dark:bg-slate-950/40">

*/
}

<section class="not-prose relative left-1/2 right-1/2 -ml-[50vw] -mr-[50vw] w-screen py-24">
  <div class="max-w-7xl mx-auto px-5">
    {/* バッジ */}
    <Badge text="二度手間からの解放" variant="tip" />

    {/* 見出しとリード文 */}
    <h2 class="text-4xl md:text-5xl mb-6 leading-tight tracking-tight">日報をエクセルに転記する<br class="md:hidden" /><span class="text-blue-600 dark:text-blue-400">「二度手間」</span>や<span class="text-red-600 dark:text-red-400">「入力ミス」</span>に悩んでいませんか？</h2>
    <p class="text-lg mb-12 leading-relaxed">
      現場から回ってくる紙やメールの日報を、毎日コツコツとエクセルに打ち直す……。 そんな「書く側」も「まとめる側」も疲弊するアナログな運用は、NipoPlusが解決します。転記作業をなくし、データ活用のスピードを圧倒的に加速させます。<br />
    </p>

    {/* メリット1 説明 */}
    <div class="grid md:grid-cols-2 gap-6 items-center mb-16">
      <div>
        <div class="text-blue-600 dark:text-blue-400 font-black text-5xl mb-4 opacity-20 italic font-serif">03</div>
        <h3 class="text-xl md:text-2xl font-bold mb-6">提出と同時にデジタル化。転記作業と入力ミスを「ゼロ」に</h3>
        <p class="leading-relaxed mb-6">現場がスマホで送信した瞬間、そのデータはすでにシステム内で集計可能な状態になっています。 紙を読み取ってエクセルに打ち直す時間はもう1秒も必要ありません。二度手間がなくなるだけでなく、書き間違いや読み間違いといった「転記ミス」も物理的に排除。正確なデータがリアルタイムに手に入ります。</p>

        {/* リンク導線 */}
        <div class="mt-16 flex justify-center lg:justify-end">
          <a href="/nipoplus/gainen/reportStorage/" class="group flex items-center gap-2 font-bold text-orange-600 dark:text-orange-400">
            すべての日報は受信BOXにて管理
            <span class="transition-transform group-hover:translate-x-1">→</span>
          </a>
        </div>
      </div>
      {/* メリット1 画像 */}
      <div>
        <div class="relative bg-white dark:bg-slate-900 rounded-2xl overflow-hidden shadow-2xl border border-slate-200 dark:border-slate-700">
          <Zoom label="様々な補助機能を組み込んだ日報作成画面">
            <Image src={IMG_Reportbox} alt="様々な補助機能を組み込んだ日報作成画面" width={1000} widths={[500, 1000]} sizes="(max-width: 500px) 500px, 1000px" class="w-full h-auto" />
          </Zoom>

          {/* オーバーレイ */}
          <div class="absolute bottom-4 left-4 right-4 bg-slate-900/80 text-white p-4 rounded-xl text-xs">
            <span>💡 デジタル化された日報は受信BOXから閲覧できます </span>
          </div>
        </div>
      </div>
    </div>

    {/* メリット2 */}
    <div class="grid md:grid-cols-2 gap-6 items-center bg-16">
      <div class="md:order-last">
        <div class="text-blue-600 dark:text-blue-400 font-black text-5xl mb-4 opacity-20 italic font-serif">04</div>
        <h3 class="text-xl md:text-2xl font-bold mb-6">溜まったデータは自動集計。グラフやPDF出力もワンクリック</h3>
        <p class="leading-relaxed mb-6">
          日報を「読むだけ」で終わらせていませんか？ NipoPlusなら、蓄積された数値を元に円グラフや棒グラフを自動生成。現場の推移を瞬時に可視化できます。<br />
          もちろん、使い慣れたエクセルでの詳細分析も可能です。CSV出力を使えば、転記なしでそのまま分析を開始。取引先への提出も、スマホ1台で綺麗なPDFを作成して送信するだけで完了します。
        </p>

        {/* リンク導線 */}
        <div class="mt-16 flex justify-center lg:justify-end">
          <a href="/nipoplus/reference/chart/" class="group flex items-center gap-2 font-bold text-orange-600 dark:text-orange-400">
            グラフ作成を見る
            <span class="transition-transform group-hover:translate-x-1">→</span>
          </a>
        </div>
      </div>
      <div class="relative group">
        <div class="relative bg-white dark:bg-slate-900 rounded-2xl overflow-hidden shadow-2xl border border-slate-200 dark:border-slate-700">
          <Zoom label="タッチパネルによる写真添付やサイン操作">
            <Image src={IMG_CSV} alt="タッチパネルによる写真添付やサイン操作" width={1000} widths={[500, 1000]} sizes="(max-width: 500px) 500px, 1000px" class="w-full h-auto" />
          </Zoom>
          {/* オーバーレイ */}
          <div class="absolute bottom-4 left-4 right-4 bg-slate-900/80 text-white p-4 rounded-xl text-xs">
            <span>💡 デジタル化の恩恵。日報データの集計や分析がよりスムーズに </span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
