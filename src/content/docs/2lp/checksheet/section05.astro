---
import { Image } from 'astro:assets'
import supportFunctionImg from './img/uservility_tablet.webp'
import { Zoom } from 'starlight-image-zoom/components'
import qrImg from './img/qrcode.webp'
---

<section class="not-prose relative left-1/2 right-1/2 -ml-[50vw] -mr-[50vw] w-screen py-24 bg-white dark:bg-slate-900 border-b border-slate-100 dark:border-slate-800">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl md:text-4xl font-black text-slate-900 dark:text-white mb-8 leading-tight tracking-tight">「どれを打てばいい？」迷う時間をゼロにします。大量の点検シートから探す手間を、QRコード1発スキャンで解決。</h2>
    <p class="text-lg text-slate-600 dark:text-slate-400 mb-10 leading-relaxed font-sans">製造現場や施設管理において、点検対象の機器が多ければ多いほど、アプリの中から「対象の点検表（テンプレート）」を探し出す作業は面倒になり、別の機器の点検表と間違える「誤点検」のリスクも高まります。</p>

    <div class="grid lg:grid-cols-2 gap-16 items-center">
      {/* 左側：ビジュアル（スマホ・タブレットの操作感） */}
      <div class="relative order-last lg:order-first">
        <div class="absolute -inset-10 bg-blue-400/10 rounded-full blur-3xl opacity-50"></div>
        <div class="relative rounded-3xl border border-slate-200 dark:border-slate-700 shadow-2xl overflow-hidden bg-slate-50 dark:bg-slate-800 p-4">
          <Zoom label="年配の方でも見やすい大きな文字の入力画面">
            <Image src={qrImg} alt="年配の方でも見やすい大きな文字の入力画面" class="rounded-xl w-full h-auto" />
          </Zoom>
          {/* 画像の上に「入力必須エラー」などのチップを合成して見せるとより伝わる */}
          <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 bg-blue-600 text-white px-4 py-2 rounded-lg font-bold shadow-xl animate-bounce">QRコードで迷い0に</div>
        </div>
      </div>

      {/* 右側：テキスト（使いやすさ ＝ ミス防止） */}
      <div>
        <div class="space-y-6">
          {/* メリット1: 使いやすさ */}
          <div class="flex items-start gap-4 p-5 bg-blue-50 dark:bg-blue-900/20 rounded-2xl border border-blue-100 dark:border-blue-800 transition-transform hover:scale-[1.02]">
            <span class="text-3xl">🖨️</span>
            <div>
              <h3 class="font-black text-slate-900 dark:text-white mb-1 font-sans">印刷して機器に貼るだけ：</h3>
              <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed font-sans">NipoPlusで発行した専用QRコードを印刷し、対象の設備や機器にペタッと貼り付けるだけ。事前の難しい設定は一切不要です。</p>
            </div>
          </div>

          {/* メリット2: ミス防止（バリデーション） */}
          <div class="flex items-start gap-4 p-5 bg-green-50 dark:bg-green-900/20 rounded-2xl border border-green-100 dark:border-green-800 transition-transform hover:scale-[1.02]">
            <span class="text-3xl">🚀</span>
            <div>
              <h3 class="font-black text-slate-900 dark:text-white mb-1 font-sans">その場で点検が即スタート：</h3>
              <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed font-sans">点検員がスマホやタブレットのカメラでスキャンすれば、その機器専用のチェックシートが1秒で起動。探す迷いや誤入力を物理的に防ぎます。</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
