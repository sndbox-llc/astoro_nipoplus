---
import { Image } from 'astro:assets'
import { Badge } from '@astrojs/starlight/components'
import { Zoom } from 'starlight-image-zoom/components'

import qrImg from './img/qrcode.webp'
---

{
  /*

このセクションコンポーネントをベースとして、コピーで使い回す

▼背景が白のセクション
<section class="not-prose relative left-1/2 right-1/2 -ml-[50vw] -mr-[50vw] w-screen py-24 bg-white dark:bg-slate-900">


▼背景がグレーのレクション
<section class="not-prose relative left-1/2 right-1/2 -ml-[50vw] -mr-[50vw] w-screen py-24 bg-slate-50 dark:bg-slate-950/40">

*/
}

<section class="not-prose relative left-1/2 right-1/2 -ml-[50vw] -mr-[50vw] w-screen py-24 bg-slate-50 dark:bg-slate-950/40">
  <div class="max-w-7xl mx-auto px-5">
    {/* バッジ */}
    <Badge text="記録を「点」から「線」へ" variant="tip" />

    {/* 見出しとリード文 */}
    <h2 class="text-4xl md:text-5xl font-black text-slate-900 dark:text-white mb-6 leading-tight tracking-tight">「どの点検シートを使うの？」迷う時間をゼロに！大量の点検シートから探す手間をQRコードスキャンで解決</h2>
    <p class="text-lg text-slate-600 dark:text-slate-400 mb-12 leading-relaxed">
      製造現場や施設管理において、点検対象の機器が多ければ多いほど、アプリの中から「対象の点検表（テンプレート）」を探し出す作業は面倒になり、別の機器の点検表と間違える「誤点検」のリスクも高まります。<br />
      NipoPlusではテンプレートごとに専用のQRコードを簡単に作成可能。点検機器にQRコードを貼り付けておけば、点検員はスマホやタブレットのカメラでスキャンするだけで、その機器専用のチェックシートが即起動。探す迷いや誤入力を物理的に防ぎます。
    </p>

    {/* メインの2カラムエリア */}
    <div class="grid lg:grid-cols-2 gap-5 items-center">
      {/* テキスト */}
      <div class="space-y-6 text-slate-600 dark:text-slate-400">
        {/* メリット1 */}
        <div class="flex gap-4">
          <div class="w-10 h-10 bg-orange-100 dark:bg-orange-900/40 rounded-full flex items-center justify-center text-orange-600 dark:text-orange-300 font-black text-lg shrink-0">1</div>

          <div>
            <h3 class="font-bold text-slate-900 dark:text-white">印刷して機器に貼るだけ：</h3>
            <p>NipoPlusで発行した専用QRコードを印刷し、対象の設備や機器にペタッと貼り付けるだけ。事前の難しい設定は一切不要です。</p>
          </div>
        </div>

        {/* メリット2 */}
        <div class="flex gap-4">
          <div class="w-10 h-10 bg-red-100 dark:bg-red-900/40 rounded-full flex items-center justify-center text-red-600 dark:text-red-300 font-black text-lg shrink-0">2</div>

          <div>
            <h3 class="font-bold text-slate-900 dark:text-white">その場で点検が即スタート：</h3>
            <p>点検員がスマホやタブレットのカメラでスキャンすれば、その機器専用のチェックシートが1秒で起動。探す迷いや誤入力を物理的に防ぎます。</p>
          </div>
        </div>
      </div>

      {/* ビジュアルセクション 画像とテキストを反転させるにはこのクラスを直下のDivに追加  lg:order-first  */}
      <div class="lg:order-first">
        <div class="relative rounded-2xl border border-slate-200 dark:border-slate-700 shadow-2xl overflow-hidden bg-white dark:bg-slate-800">
          <Zoom label="設備点検の推移をリアルタイムでグラフ化する画面">
            <Image src={qrImg} alt="設備点検の推移をリアルタイムでグラフ化する画面" />
          </Zoom>

          {/* オーバーレイ */}
          <div class="absolute bottom-4 left-4 right-4 bg-slate-900/80 text-white p-4 rounded-xl text-xs">
            <span>💡 送信された点検結果が即座にプロットされます。Excel不要のスピード経営へ。 </span>
          </div>
        </div>
      </div>
    </div>
    {/* リンク導線 */}
    <div class="mt-16 flex justify-center lg:justify-end">
      <a href="/nipoplus/reference/qrtemplate/" class="group flex items-center gap-2 font-bold text-orange-600 dark:text-orange-400">
        QRコードについて詳しく知る
        <span class="transition-transform group-hover:translate-x-1">→</span>
      </a>
    </div>
  </div>
</section>
