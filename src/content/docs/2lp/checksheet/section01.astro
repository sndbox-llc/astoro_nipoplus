---
import { Image } from 'astro:assets'
import { Badge } from '@astrojs/starlight/components'
import { Zoom } from 'starlight-image-zoom/components'

import ExcelTable from '@components/ExcelTable.astro'
---

{
  /*

このセクションコンポーネントをベースとして、コピーで使い回す

▼背景が白のセクション
<section class="not-prose relative left-1/2 right-1/2 -ml-[50vw] -mr-[50vw] w-screen py-24 bg-white dark:bg-slate-900">


▼背景がグレーのレクション
<section class="not-prose relative left-1/2 right-1/2 -ml-[50vw] -mr-[50vw] w-screen py-24 bg-slate-50 dark:bg-slate-950/40">

*/
}

<section class="not-prose relative left-1/2 right-1/2 -ml-[50vw] -mr-[50vw] w-screen py-24 bg-slate-50 dark:bg-slate-950/40">
  <div class="max-w-7xl mx-auto px-5">
    {/* バッジ */}
    <Badge text="ペーパーレスの恩恵" variant="tip" />

    {/* 見出しとリード文 */}
    <h2 class="text-4xl md:text-5xl font-black text-slate-900 dark:text-white mb-6 leading-tight tracking-tight">10年分の点検記録の「保管場所」にも困りません。紙の管理に比べて多くの利点があります</h2>
    <p class="text-lg text-slate-600 dark:text-slate-400 mb-12 leading-relaxed">設備点検のデータは「資産」ですが、紙のままだと場所を取るだけの「負債」になりかねません。 物理的なスペースを解放し、必要な時に1秒で見つかるデジタル管理へ移行しましょう。蓄積されたデータはいつでもCSV出力可能。10年後のシステム環境を心配する必要はありません。</p>

    {/* メインの2カラムエリア */}
    <div class="grid lg:grid-cols-2 gap-5 items-center">
      {/* テキスト */}
      <div class="space-y-6 text-slate-600 dark:text-slate-400">
        {/* メリット1 */}
        <div class="flex gap-4">
          <div class="w-10 h-10 bg-orange-100 dark:bg-orange-900/40 rounded-full flex items-center justify-center text-orange-600 dark:text-orange-300 font-black text-lg shrink-0">1</div>

          <div>
            <h3 class="font-bold text-slate-900 dark:text-white">保管コストを「ゼロ」へ</h3>
            <p>段ボール箱で埋まっていた一部屋が、丸ごと別の用途に。ファイル代や倉庫代を劇的に削減します。</p>
          </div>
        </div>

        {/* メリット2 */}
        <div class="flex gap-4">
          <div class="w-10 h-10 bg-red-100 dark:bg-red-900/40 rounded-full flex items-center justify-center text-red-600 dark:text-red-300 font-black text-lg shrink-0">2</div>

          <div>
            <h3 class="font-bold text-slate-900 dark:text-white">「あの時の記録」を即検索</h3>
            <p>監査時に慌てる必要はありません。日付や機器名で検索すれば、目的のデータが瞬時に現れます。</p>
          </div>
        </div>
        {/* メリット3 */}
        <div class="flex gap-4">
          <div class="w-10 h-10 bg-red-100 dark:bg-red-900/40 rounded-full flex items-center justify-center text-pink-600 dark:text-red-300 font-black text-lg shrink-0">3</div>

          <div>
            <h3 class="font-bold text-slate-900 dark:text-white">劣化・紛失リスクに強い</h3>
            <p>紙のような劣化や、紛失・災害リスクに無防備ではありません。クラウドが大切な証跡を守り抜きます。</p>
          </div>
        </div>
      </div>

      {/* ビジュアルセクション 画像とテキストを反転させるにはこのクラスを直下のDivに追加  lg:order-first  */}
      <div class="lg:order-first">
        <div class="relative rounded-2xl border border-slate-200 dark:border-slate-700 shadow-2xl overflow-hidden bg-white dark:bg-slate-800">
          {/* ワイドに表示されるExcelTable */}
          <div class="p-4 md:p-8 overflow-x-auto">
            <div class="absolute top-6 right-8 z-10 hidden sm:flex flex-col gap-3 items-end">
              <div class="bg-blue-600 text-white px-4 py-2 rounded-xl font-bold text-sm shadow-2xl flex items-center gap-2 animate-bounce">
                <span>🍃</span> CSVデータなら物理保管場所は０
              </div>
              <div class="bg-slate-800/90 text-white px-4 py-1.5 rounded-full text-xs border border-slate-700 shadow-lg opacity-0 group-hover:opacity-100 transition-all duration-500 transform translate-x-4 group-hover:translate-x-0">10年分のデータもこの中に</div>
            </div>

            {/* prettier-ignore */}
            <ExcelTable>
              {
                `
            提出日, 【-2mm】線形ズレ, 【-1mm】線形ズレ, 【0】線形ズレ, 【+1mm】線形ズレ, 【+2mm】線形ズレ, 【-2mm】X軸ズレ, 【-1mm】X軸ズレ, 【0】X軸ズレ, 【+1mm】X軸ズレ, 【+2mm】X軸ズレ, 【-2mm】Y軸ズレ, 【-1mm】Y軸ズレ, 【0】Y軸ズレ, 【+1mm】Y軸ズレ, 【+2mm】Y軸ズレ, 【-2mm】Z軸ズレ, 【-1mm】Z軸ズレ, 【0】Z軸ズレ, 【+1mm】Z軸ズレ, 【+2mm】Z軸ズレ, 【合格】合否, 【不合格】合否, 備考
            2024/05/14 10:26, , , ⭕, , , , ⭕, , , , , , , , ⭕, , , ⭕, , , ⭕, ,
            2023/04/11 01:23, , , ⭕, , , , , ⭕, , , , , ⭕, , , , ⭕, , , , ⭕, ,
            2023/02/16 11:35, , , ⭕, , , , , ⭕, , , , , , ⭕, , , ⭕, , , , ⭕, , "サンプルです実在する部品とは無関係です"
            2023/02/14 11:35, , , ⭕, , , , ⭕, , , , ⭕, , , , , , , ⭕, , , , ⭕, Y軸ずれ
            2023/02/12 11:35, ⭕, , , , , ⭕, , , , , , , , , ⭕, ⭕, , , , , , ⭕, ジャストがない
            2023/02/11 11:35, , , ⭕, , , , , ⭕, , , , , ⭕, , , , , , ⭕, , ⭕, ,
            2023/02/09 11:51, , , ⭕, , , , , ⭕, , , , , , ⭕, , , ⭕, , , , ⭕, , "サンプルです実在する部品とは無関係です"
            `
              }
            </ExcelTable>
          </div>
        </div>
      </div>
    </div>
    {/* リンク導線 */}
    <div class="mt-16 flex justify-center lg:justify-end">
      <a href="/nipoplus/staff/csv/" class="group flex items-center gap-2 font-bold text-orange-600 dark:text-orange-400">
        CSV出力の詳細を見る
        <span class="transition-transform group-hover:translate-x-1">→</span>
      </a>
    </div>
  </div>
</section>
