---
import { Card, CardGrid, Steps, LinkCard, Icon } from '@astrojs/starlight/components'
import { Image } from 'astro:assets'
import ExcelTable from '@components/ExcelTable.astro'

import dxImg from './img/checksheet_tablet.webp'
import supportFunctionImg from './img/uservility_tablet.webp'
import chartImg from './img/chart_tablet.webp'
import multiDeviceImg from './img/factory-usage.webp'
import improveImg from './img/seihin_tablet.webp'
import costImg from './img/lawprice.webp'

---

<section class="not-prose relative left-1/2 right-1/2 -ml-[50vw] -mr-[50vw] w-screen py-24 bg-slate-50 dark:bg-slate-900/40 border-y border-slate-200 dark:border-slate-800 font-sans">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    
    {/* 1. 見出しセクション */}
    <div class="text-center mb-20">
      <h2 class="text-3xl md:text-5xl font-black text-slate-900 dark:text-white mb-6 tracking-tight leading-tight">
        10年分の点検記録、<br class="md:hidden" />「保管場所」に限界を感じていませんか？
      </h2>
      <p class="text-lg text-slate-600 dark:text-slate-400 max-w-3xl mx-auto leading-relaxed">
        設備点検のデータは「資産」ですが、紙のままだと場所を取るだけの「負債」になりかねません。<br />
        物理的なスペースを解放し、必要な時に1秒で見つかるデジタル管理へ移行しましょう。
      </p>
    </div>

    {/* 2. 3つのメリット（横並びグリッド） */}
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-16">
      <div class="p-8 bg-white dark:bg-slate-800 rounded-3xl shadow-sm border border-slate-200 dark:border-slate-700 transition-all hover:shadow-md hover:-translate-y-1">
        <div class="text-4xl mb-4">📦</div>
        <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-3">保管コストを「ゼロ」へ</h3>
        <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">
          段ボール箱で埋まっていた一部屋が、丸ごと別の用途に。ファイル代や倉庫代を劇的に削減します。
        </p>
      </div>

      <div class="p-8 bg-white dark:bg-slate-800 rounded-3xl shadow-sm border border-slate-200 dark:border-slate-700 transition-all hover:shadow-md hover:-translate-y-1">
        <div class="text-4xl mb-4">🔍</div>
        <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-3">「あの時の記録」を即検索</h3>
        <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">
          監査時に慌てる必要はありません。日付や機器名で検索すれば、目的のデータが瞬時に現れます。
        </p>
      </div>

      <div class="p-8 bg-white dark:bg-slate-800 rounded-3xl shadow-sm border border-slate-200 dark:border-slate-700 transition-all hover:shadow-md hover:-translate-y-1">
        <div class="text-4xl mb-4">🛡️</div>
        <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-3">劣化・紛失リスクに強い</h3>
        <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">
          紙のような劣化や、紛失・災害リスクに無防備ではありません。クラウドが大切な証跡を守り抜きます。
        </p>
      </div>
    </div>

    {/* 3. ワイドなExcelTable（遊び心チップ付き） */}
    <div class="relative group">
      {/* 背後の装飾 */}
      <div class="absolute -inset-4 bg-gradient-to-r from-blue-600/10 to-indigo-600/10 rounded-full blur-3xl opacity-60 group-hover:opacity-100 transition duration-700"></div>
      
      <div class="relative bg-white dark:bg-slate-900 rounded-3xl border border-slate-200 dark:border-slate-700 shadow-2xl overflow-hidden">
        
        {/* ★遊び心チップ（右上に固定） */}
        <div class="absolute top-6 right-8 z-10 hidden sm:flex flex-col gap-3 items-end">
          <div class="bg-blue-600 text-white px-4 py-2 rounded-xl font-bold text-sm shadow-2xl flex items-center gap-2 animate-bounce">
            <span>🍃</span> 物理的な保管場所は「ゼロ」へ
          </div>
          <div class="bg-slate-800/90 text-white px-4 py-1.5 rounded-full text-xs border border-slate-700 shadow-lg opacity-0 group-hover:opacity-100 transition-all duration-500 transform translate-x-4 group-hover:translate-x-0">
            10年分のデータもこの中に
          </div>
        </div>

        {/* ワイドに表示されるExcelTable */}
        <div class="p-4 md:p-8 overflow-x-auto">
          {/* prettier-ignore */}
          <ExcelTable>
            提出日, 【-2mm】線形ズレ, 【-1mm】線形ズレ, 【0】線形ズレ, 【+1mm】線形ズレ, 【+2mm】線形ズレ, 【-2mm】X軸ズレ, 【-1mm】X軸ズレ, 【0】X軸ズレ, 【+1mm】X軸ズレ, 【+2mm】X軸ズレ, 【-2mm】Y軸ズレ, 【-1mm】Y軸ズレ, 【0】Y軸ズレ, 【+1mm】Y軸ズレ, 【+2mm】Y軸ズレ, 【-2mm】Z軸ズレ, 【-1mm】Z軸ズレ, 【0】Z軸ズレ, 【+1mm】Z軸ズレ, 【+2mm】Z軸ズレ, 【合格】合否, 【不合格】合否, 備考
            2024/05/14 10:26, , , ⭕, , , , ⭕, , , , , , , , ⭕, , , ⭕, , , ⭕, ,
            2023/04/11 01:23, , , ⭕, , , , , ⭕, , , , , ⭕, , , , ⭕, , , , ⭕, ,
            2023/02/16 11:35, , , ⭕, , , , , ⭕, , , , , , ⭕, , , ⭕, , , , ⭕, , "サンプルです実在する部品とは無関係です"
            2023/02/14 11:35, , , ⭕, , , , ⭕, , , , ⭕, , , , , , , ⭕, , , , ⭕, Y軸ずれ
            2023/02/12 11:35, ⭕, , , , , ⭕, , , , , , , , , ⭕, ⭕, , , , , , ⭕, ジャストがない
            2023/02/11 11:35, , , ⭕, , , , , ⭕, , , , , ⭕, , , , , , ⭕, , ⭕, ,
            2023/02/09 11:51, , , ⭕, , , , , ⭕, , , , , , ⭕, , , ⭕, , , , ⭕, , "サンプルです実在する部品とは無関係です"
          </ExcelTable>
        </div>
      </div>
    </div>

    {/* 4. 誘導テキスト */}
    <div class="mt-12 text-center">
      <p class="text-slate-500 text-sm mb-6 italic">
        ※ 蓄積されたデータはいつでもCSV出力可能。10年後のシステム環境を心配する必要はありません。
      </p>
      <a href="/nipoplus/price/" class="inline-flex items-center text-blue-600 dark:text-blue-400 font-bold hover:underline gap-2 group">
        データ保管の仕様について詳しく知る 
        <span class="transition-transform group-hover:translate-x-1">→</span>
      </a>
    </div>

  </div>
</section>