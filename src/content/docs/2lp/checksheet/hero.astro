---
import { Image } from 'astro:assets'
import multiDeviceImg from './img/factory-usage.webp'
import { LinkButton } from '@astrojs/starlight/components'
import { Zoom } from 'starlight-image-zoom/components'
---

<section class="not-prose relative left-1/2 right-1/2 -ml-[50vw] -mr-[50vw] w-screen overflow-hidden py-20 lg:py-28">
  <!-- max-w-5xl に絞ることで、中央寄せのテキストが横に広がりすぎず読みやすくなります -->
  <div class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center flex flex-col items-center">
    {/* 1. メインキャッチコピー */}
    <h2 class="text-4xl md:text-6xl font-black text-slate-900 dark:text-white mb-6 leading-[1.2] tracking-tight">
      今のエクセル点検表を、<br />そのままスマホ・タブレットへ。
    </h2>

    {/* 2. サブリード文 */}
    <p class="text-lg md:text-xl text-slate-600 dark:text-slate-400 mb-10 leading-relaxed max-w-2xl">
      点検シートを選んだら、フォーマットに沿ってタップするだけの簡単入力。写真添付や手書きサインにも対応し、送信されたデータは自動で集計・PDF出力も簡単です<br />
      NipoPlusは、年配の方でも迷わず使えるシンプルさと、現場に合わせた自由なカスタマイズを両立した、業界最安値クラスの点検表アプリです。
    </p>

    {/* 3. アクションボタン（CTA） */}
    <div class="flex flex-col sm:flex-row gap-4 mb-16 w-full sm:w-auto justify-center">
      <LinkButton href="https://nipoplus.sndbox.jp/" target="_blank">今すぐ無料で体験する</LinkButton>
      <LinkButton href="/nipoplus/admin/quickstart/" variant="secondary" icon="external" iconPlacement="start"> 操作ガイドを見る </LinkButton>
    </div>

    {/* 4. ビジュアル（特大サイズのタブレット画面） */}
    <div class="relative w-full mb-16 group">
      <div class="absolute -inset-4 bg-blue-500/10 rounded-full blur-3xl opacity-0 dark:opacity-30"></div>
      <div class="relative rounded-2xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800/50 p-3 shadow-2xl overflow-hidden">
        <Zoom label="作業台で製品の検品点検にNipoPlusを使用している実際の様子です。自動車部品メーカ様よりご提供いただきました。画面は意図的に若干のボカシを入れています。">
          {/* w-full で横幅いっぱいに広げ、操作画面のディテールをくっきり見せます */}
          <Image src={multiDeviceImg} alt="作業台で製品の検品点検にNipoPlusを使用している実際の様子です。自動車部品メーカ様よりご提供いただきました。画面は意図的に若干のボカシを入れています。" class="rounded-xl w-full h-auto transform group-hover:scale-[1.01] transition-transform duration-500" />
        </Zoom>
      </div>
    </div>

    {/* 5. ★日報LPへのリンク（最下部にスマートに配置） */}
    <div class="p-4 rounded-xl bg-slate-100 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 w-full max-w-md text-left sm:text-center">
      <p class="text-slate-600 dark:text-slate-400 text-sm mb-1 font-bold font-sans">日報アプリでお探しですか？</p>
      <a href="/" class="group inline-flex items-center text-blue-600 dark:text-indigo-400 font-bold hover:text-blue-500 dark:hover:text-indigo-300 transition-colors gap-1 text-sm font-sans">
        日報業務に特化した解説ページはこちら
        <span class="transition-transform group-hover:translate-x-1">→</span>
      </a>
    </div>
  </div>
</section>
