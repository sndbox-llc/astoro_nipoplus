---
// src/components/lp/CheckAnalysis.astro
import { Image } from 'astro:assets'
import IMG_RealtimeChart from './img/chart_tablet.webp' // 既存のグラフ画像
import { Zoom } from 'starlight-image-zoom/components'
---

<section class="not-prose relative left-1/2 right-1/2 -ml-[50vw] -mr-[50vw] w-screen py-24 bg-white dark:bg-slate-900 border-b border-slate-100 dark:border-slate-800">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-orange-500/10 border border-orange-500/20 text-orange-600 dark:text-orange-400 text-sm font-bold mb-6 font-sans">📈 記録を「点」から「線」へ</div>

    <h2 class="text-3xl md:text-4xl font-black text-slate-900 dark:text-white mb-8 leading-tight tracking-tight">数値の「わずかな異変」を、 グラフが教えてくれる。</h2>

    <p class="text-lg text-slate-600 dark:text-slate-400 mb-8 leading-relaxed font-sans">
      点検データは、ただ記録するだけでは不十分です。真の価値は「過去との比較」にあります。<br />
      NipoPlusなら、現場でデータが送信された瞬間にグラフが自動更新。Excelへの転記や集計作業を待つことなく、異常の予兆をリアルタイムに察知できます。
    </p>

    <div class="grid lg:grid-cols-2 gap-16 items-center">
      {/* 左側：テキスト（分析・予防保全の価値） */}
      <div>
        <div class="grid gap-6">
          {/* メリット1: リアルタイム */}
          <div class="flex gap-4">
            <div class="flex-none w-10 h-10 bg-orange-100 dark:bg-orange-900/40 rounded-full flex items-center justify-center text-orange-600 dark:text-orange-300">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
            </div>
            <div>
              <h3 class="font-bold text-slate-900 dark:text-white mb-1 font-sans">集計・グラフ化は「自動」</h3>
              <p class="text-sm text-slate-600 dark:text-slate-400 font-sans">点検員が報告を送信したその瞬間にグラフが反映。管理者がデータをまとめる時間は「ゼロ」になります。</p>
            </div>
          </div>

          {/* メリット2: 異常の早期発見 */}
          <div class="flex gap-4">
            <div class="flex-none w-10 h-10 bg-red-100 dark:bg-red-900/40 rounded-full flex items-center justify-center text-red-600 dark:text-red-300">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
            </div>
            <div>
              <h3 class="font-bold text-slate-900 dark:text-white mb-1 font-sans">数値に埋もれる「乖離」を可視化</h3>
              <p class="text-sm text-slate-600 dark:text-slate-400 font-sans">単発の数値では見落としがちな「徐々に上がっている値」や「突発的な乖離」も、折れ線グラフなら一目で把握。重大な故障を防ぐ「予防保全」を実現します。</p>
            </div>
          </div>
        </div>
      </div>

      {/* 右側：ビジュアル */}
      <div class="relative group">
        <div class="absolute -inset-4 bg-orange-500/10 rounded-full blur-3xl opacity-50 group-hover:opacity-80 transition duration-700"></div>
        <div class="relative rounded-3xl border border-slate-200 dark:border-slate-700 shadow-2xl overflow-hidden bg-white dark:bg-slate-800">
          <Zoom label="設備点検の推移をリアルタイムでグラフ化する画面">
            <Image src={IMG_RealtimeChart} alt="設備点検の推移をリアルタイムでグラフ化する画面" class="w-full h-auto transition-transform duration-500 group-hover:scale-[1.01]" />
          </Zoom>

          {/* オーバーレイ：リアルタイム更新中の演出 */}
          <div class="absolute bottom-6 left-6 right-6 p-4 bg-slate-900/90 backdrop-blur rounded-2xl border border-white/10 shadow-2xl">
            <div class="flex items-center gap-3">
              <div class="w-3 h-3 bg-green-500 rounded-full animate-pulse"></div>
              <div class="text-white text-xs font-bold font-sans tracking-wider uppercase">Live Data: 機器稼働率</div>
            </div>
            <div class="mt-2 text-slate-400 text-[10px] font-sans leading-tight">送信された点検結果が即座にプロットされます。Excel不要のスピード経営へ。</div>
          </div>
        </div>
      </div>
    </div>

    {/* リンク導線 */}
    <div class="mt-16 flex justify-center lg:justify-start">
      <a href="/nipoplus/staff/charts/" class="group flex items-center gap-2 font-bold text-orange-600 dark:text-orange-400 hover:underline font-sans">
        集計・可視化機能について詳しく知る
        <span class="transition-transform group-hover:translate-x-1">→</span>
      </a>
    </div>
  </div>
</section>
