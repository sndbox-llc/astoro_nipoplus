---
// src/components/lp/CheckAnalysis.astro
import { Image } from 'astro:assets'
import IMG_RealtimeChart from './img/chart_tablet.webp'
import { Badge } from '@astrojs/starlight/components'
import { Zoom } from 'starlight-image-zoom/components'
---

{
  /*

このセクションコンポーネントをベースとして、コピーで使い回す

▼背景が白のセクション
<section class="not-prose relative left-1/2 right-1/2 -ml-[50vw] -mr-[50vw] w-screen py-24 bg-white dark:bg-slate-900">


▼背景がグレーのレクション
<section class="not-prose relative left-1/2 right-1/2 -ml-[50vw] -mr-[50vw] w-screen py-24 bg-slate-50 dark:bg-slate-950/40">

*/
}

<section class="not-prose relative left-1/2 right-1/2 -ml-[50vw] -mr-[50vw] w-screen py-24 bg-slate-50 dark:bg-slate-950/40">
  <div class="max-w-7xl mx-auto px-5">
    {/* バッジ */}
    <Badge text="記録を「点」から「線」へ" variant="tip" />

    {/* 見出しとリード文 */}
    <h2 class="text-4xl md:text-5xl font-black text-slate-900 dark:text-white mb-6 leading-tight tracking-tight">数値の「わずかな異変」を、グラフが教えてくれる。</h2>
    <p class="text-lg text-slate-600 dark:text-slate-400 mb-12 leading-relaxed">
      点検データは、ただ記録するだけでは不十分です。真の価値は「過去との比較」にあります。<br />
      NipoPlusなら、現場でデータが送信された瞬間にグラフが自動更新。Excelへの転記や集計作業を待つことなく、異常の予兆をリアルタイムに察知できます。
    </p>

    {/* メインの2カラムエリア */}
    <div class="grid lg:grid-cols-2 gap-5 items-center">
      {/* テキスト */}
      <div class="space-y-6 text-slate-600 dark:text-slate-400">
        {/* メリット1 */}
        <div class="flex gap-4">
          <div class="w-10 h-10 bg-orange-100 dark:bg-orange-900/40 rounded-full flex items-center justify-center text-orange-600 dark:text-orange-300 shrink-0">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
          </div>
          <div>
            <h3 class="font-bold text-slate-900 dark:text-white">集計・グラフ化は「自動」</h3>
            <p>点検員が報告を送信したその瞬間にグラフが反映。管理者がデータをまとめる時間は「ゼロ」になります。</p>
          </div>
        </div>

        {/* メリット2 */}
        <div class="flex gap-4">
          <div class="w-10 h-10 bg-red-100 dark:bg-red-900/40 rounded-full flex items-center justify-center text-red-600 dark:text-red-300 shrink-0">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
          </div>
          <div>
            <h3 class="font-bold text-slate-900 dark:text-white">数値に埋もれる「乖離」を可視化</h3>
            <p>単発の数値では見落としがちな「徐々に上がっている値」や「突発的な乖離」も、折れ線グラフなら一目で把握。重大な故障を防ぐ「予防保全」を実現します。</p>
          </div>
        </div>
      </div>

      {/* ビジュアルセクション 画像とテキストを反転させるにはこのクラスを直下のDivに追加  lg:order-first  */}
      <div class="lg:order-first">
        <div class="relative rounded-2xl border border-slate-200 dark:border-slate-700 shadow-2xl overflow-hidden bg-white dark:bg-slate-800">
          <Zoom label="設備点検の推移をリアルタイムでグラフ化する画面">
            <Image src={IMG_RealtimeChart} alt="設備点検の推移をリアルタイムでグラフ化する画面" />
          </Zoom>

          {/* オーバーレイ */}
          <div class="absolute bottom-4 left-4 right-4 bg-slate-900/80 text-white p-4 rounded-xl text-xs">
            <span>💡 送信された点検結果が即座にプロットされます。Excel不要のスピード経営へ。 </span>
          </div>
        </div>
      </div>
    </div>
    {/* リンク導線 */}
    <div class="mt-16 flex justify-center lg:justify-end">
      <a href="/nipoplus/staff/charts/" class="group flex items-center gap-2 font-bold text-orange-600 dark:text-orange-400">
        集計・可視化機能について詳しく知る
        <span class="transition-transform group-hover:translate-x-1">→</span>
      </a>
    </div>
  </div>
</section>
