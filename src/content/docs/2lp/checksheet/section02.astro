---
import { Card, CardGrid, Steps, LinkCard, Icon } from '@astrojs/starlight/components'
import { Image } from 'astro:assets'
import ExcelTable from '@components/ExcelTable.astro'

import dxImg from './img/checksheet_tablet.webp'
import supportFunctionImg from './img/uservility_tablet.webp'
import { Zoom } from 'starlight-image-zoom/components'

import chartImg from './img/chart_tablet.webp'
import multiDeviceImg from './img/factory-usage.webp'
import improveImg from './img/seihin_tablet.webp'
import costImg from './img/lawprice.webp'
---

<section class="not-prose relative left-1/2 right-1/2 -ml-[50vw] -mr-[50vw] w-screen py-24 bg-white dark:bg-slate-900 border-b border-slate-100 dark:border-slate-800">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl md:text-4xl font-black text-slate-900 dark:text-white mb-8 leading-tight tracking-tight">「現場が迷わない」ことが、 最強のミス防止策になる。</h2>
    <p class="text-lg text-slate-600 dark:text-slate-400 mb-10 leading-relaxed font-sans">「うっかり記入漏れ」や「手順飛ばし」は、個人の意識の問題ではなく、システムの設計で解決すべき課題です。NipoPlusは、現場のストレスをなくし、同時に報告の精度を底上げします。</p>

    <div class="grid lg:grid-cols-2 gap-16 items-center">
      {/* 左側：ビジュアル（スマホ・タブレットの操作感） */}
      <div class="relative order-last lg:order-first">
        <div class="absolute -inset-10 bg-blue-400/10 rounded-full blur-3xl opacity-50"></div>
        <div class="relative rounded-3xl border border-slate-200 dark:border-slate-700 shadow-2xl overflow-hidden bg-slate-50 dark:bg-slate-800 p-4">
          <Zoom label="年配の方でも見やすい大きな文字の入力画面">
            <Image src={supportFunctionImg} alt="年配の方でも見やすい大きな文字の入力画面" class="rounded-xl w-full h-auto" />
          </Zoom>
          {/* 画像の上に「入力必須エラー」などのチップを合成して見せるとより伝わる */}
          <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 bg-red-600 text-white px-4 py-2 rounded-lg font-bold shadow-xl animate-bounce">⚠️ 入力漏れがあります！</div>
        </div>
      </div>

      {/* 右側：テキスト（使いやすさ ＝ ミス防止） */}
      <div>
        <div class="space-y-6">
          {/* メリット1: 使いやすさ */}
          <div class="flex items-start gap-4 p-5 bg-blue-50 dark:bg-blue-900/20 rounded-2xl border border-blue-100 dark:border-blue-800 transition-transform hover:scale-[1.02]">
            <span class="text-3xl">👓</span>
            <div>
              <h3 class="font-black text-slate-900 dark:text-white mb-1 font-sans">年配の方にも優しい「見える」UI</h3>
              <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed font-sans">キーボード入力は最小限。大きな選択ボタン、自由に変えられるフォントサイズ。スマホが苦手なベテラン点検員から「これなら楽だ」と喜ばれています。</p>
            </div>
          </div>

          {/* メリット2: ミス防止（バリデーション） */}
          <div class="flex items-start gap-4 p-5 bg-green-50 dark:bg-green-900/20 rounded-2xl border border-green-100 dark:border-green-800 transition-transform hover:scale-[1.02]">
            <span class="text-3xl">🛑</span>
            <div>
              <h3 class="font-black text-slate-900 dark:text-white mb-1 font-sans">「未記入」なら送信させない強制力</h3>
              <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed font-sans">必須項目が空欄だとエラーを表示し、送信をブロック。紙では防げなかった「空欄」や「写真の撮り忘れ」を物理的にゼロにします。</p>
            </div>
          </div>

          {/* メリット3: 手順制御 */}
          <div class="flex items-start gap-4 p-5 bg-orange-50 dark:bg-orange-900/20 rounded-2xl border border-orange-100 dark:border-orange-800 transition-transform hover:scale-[1.02]">
            <span class="text-3xl">👣</span>
            <div>
              <h3 class="font-black text-slate-900 dark:text-white mb-1 font-sans">点検手順を迷わせない「動的制御」</h3>
              <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed font-sans">「異常あり」と答えた時だけ詳細項目が現れるなど、状況に応じた最適な設問を提示。不慣れな点検員でも、迷わず正しい手順を遵守できます。</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    {/* リンク導線 */}
    <div class="mt-16 pt-8 border-t border-slate-100 dark:border-slate-800 flex justify-center lg:justify-end">
      <a href="/nipoplus/template/selects/#dinamic_switch_select" class="group inline-flex items-center gap-2 font-bold text-blue-600 dark:text-blue-400 hover:underline">
        動的変化について詳しくみる
        <span class="transition-transform group-hover:translate-x-1">→</span>
      </a>
    </div>
  </div>
</section>
