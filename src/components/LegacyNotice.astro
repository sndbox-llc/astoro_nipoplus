---
import type { ComponentProps } from 'astro/types'
import Default from '@astrojs/starlight/components/Banner.astro'
import { Aside } from '@astrojs/starlight/components'

type Props = ComponentProps<typeof Default>

const { entry } = Astro.props
// URLに /legacy/ が含まれる場合に表示
const showLegacyNotice = Astro.url.pathname.includes('/legacy/')
---

{
  showLegacyNotice && (
    <Aside type="caution" title="旧バージョンガイド">
      ご覧のページはNipo（旧バージョン）のガイドです。今から始める方は
      <a href="/nipoplus/admin/quickstart/">NipoPlus</a> をご検討ください。
    </Aside>
  )
}

<Default {...Astro.props}><slot /></Default>
