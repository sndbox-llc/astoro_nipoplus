{/* 🐧 キャラクター＆吹き出し（横並びインライン版） */}
<div class="flex items-center justify-center gap-3 mb-6 w-full animate-bounce [animation-duration:4s]">
  {/* 💬 吹き出し（左側） */}
  <div class="relative px-4 py-2 rounded-2xl text-xs font-black shadow-sm border text-center max-w-[220px]
              /* ☀️ ライトモード */
              bg-amber-100 text-amber-800 border-amber-200
              /* 🌙 ダークモード */
              dark:bg-amber-950 dark:text-amber-300 dark:border-amber-900/50">
    使ってみてね

    {/* 吹き出しのトゲ（右側のキャラクターの口元を向くように調整） */}
    <div class="absolute top-1/2 right-[-5px] -translate-y-1/2 w-2.5 h-2.5 rotate-45
                bg-amber-100 border-t border-r border-amber-200
                dark:bg-amber-950 dark:border-amber-900/50"></div>
  </div>

  {/* 👩‍🦰 キャラクター画像（右側） */}
  {/* rounded-full と overflow-hidden を追加 */}
  <div class="w-16 h-16 md:w-20 md:h-20 shrink-0 rounded-full overflow-hidden">
    <img src="/images/ok.png" alt="マスコットキャラクター" class="w-full h-auto object-contain" />
  </div>
</div>

<div class="cta-card my-16 mx-auto max-w-[650px] p-8 md:p-12 text-center rounded-3xl border transition-colors duration-300
            /* ☀️ ライトモード */
            bg-gradient-to-br from-white to-slate-50 border-slate-200 shadow-xl shadow-slate-200/50
            /* 🌙 ダークモード */
            dark:from-slate-900 dark:to-slate-950 dark:border-slate-800 dark:shadow-none">
  <div class="flex flex-col items-center">
    {/* ロゴ */}
    <div class="mb-6">
      <img src="/images/favicon.svg" alt="NipoPlus logo" width="100" height="100" class="w-24 h-24" />
    </div>

    {/* キャッチコピー */}
    <h3 class="text-2xl md:text-3xl font-black mb-4 border-none text-slate-800 dark:text-slate-100">現場のDXを、もっと軽やかに。</h3>

    {/* 説明文 */}
    <p class="text-base leading-relaxed mb-8 max-w-md text-slate-500 dark:text-slate-400">
      日報・チェックリスト作成を電子化する「NipoPlus」。<br />
      まずは無料トライアルで、その使い心地を体験してください。
    </p>

    {/* ボタン・バナーエリア */}
    <div class="flex flex-col items-center gap-6 w-full">
      {/* ボタン2つ */}
      <div class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto justify-center">
        {/* メインボタン（紫） */}
        <a href="https://nipoplus.sndbox.jp/" target="_blank" class="inline-block px-10 py-3.5 rounded-full font-bold text-base text-white transition-all transform hover:-translate-y-0.5 no-underline hover:no-underline shadow-lg
                  bg-purple-600 hover:bg-purple-700 shadow-purple-600/20
                  dark:bg-purple-500 dark:hover:bg-purple-400 dark:shadow-none"> Webで無料で始める </a>

        {/* サブボタン（グレー） */}
        <a href="/nipoplus/admin/quickstart/" target="_blank" class="inline-block px-10 py-3.5 rounded-full font-bold text-base border transition-all transform hover:-translate-y-0.5 no-underline hover:no-underline
                  bg-slate-100 text-slate-700 border-slate-300 hover:bg-slate-200
                  dark:bg-slate-800 dark:text-slate-200 dark:border-slate-700 dark:hover:bg-slate-700"> 操作ガイド </a>
      </div>

      {/* ストアバナー */}
      <div class="flex justify-center items-center gap-4 flex-wrap mt-2">
        <a href="/nipoplus/system/mobile-install/#ios_usage" target="_blank" class="hover:opacity-80 transition-opacity">
          <img src="/images/apple.svg" width="130" alt="App Storeからダウンロード" class="h-10 w-auto dark:invert dark:brightness-200" />
        </a>
        <a href="/nipoplus/system/mobile-install/#android_usage" target="_blank" class="hover:opacity-80 transition-opacity">
          <img src="/images/google-play-badge.png" width="100" alt="Google Playで手に入れよう" class="h-14 -my-2 w-auto" />
        </a>
      </div>
    </div>
  </div>
</div>
